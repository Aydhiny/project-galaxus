DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

AUTH_SECRET=your-secret-key-at-least-32-chars

# Public site URL — used for canonical links, sitemap, robots.txt, and
# Open Graph metadata. Defaults to VERCEL_URL on Vercel, localhost otherwise.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — error monitoring. Leave unset to skip Sentry entirely.
# NEXT_PUBLIC_SENTRY_DSN=

# Optional — transactional email (password reset, email verification).
# Without it, reset/verify links are logged to the server console instead of emailed.
# RESEND_API_KEY=

# Required for the weekly digest cron endpoint (app/api/cron/weekly-digest).
# Pick any random string yourself — this isn't a third-party credential, it's
# just a shared secret between Vercel Cron and this route. Without it, the
# route always returns 401.
# CRON_SECRET=

# Optional — "Continue with Google" on login/register. Both buttons stay
# hidden until their env vars are set. Create a client at
# https://console.cloud.google.com/apis/credentials and register this
# redirect URI: {NEXT_PUBLIC_SITE_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional — "Continue with GitHub" on login/register. Create an OAuth App at
# https://github.com/settings/developers and register this callback URL:
# {NEXT_PUBLIC_SITE_URL}/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Required for Stripe billing (Pro plan upgrade). Get keys from
# https://dashboard.stripe.com/test/apikeys (use test-mode keys while developing).
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# The recurring Price ID for the Pro plan subscription (starts with "price_").
# Create a Product + recurring Price in the Stripe Dashboard, then paste the Price id here.
# STRIPE_PRO_PRICE_ID=

# Required to verify Stripe webhook signatures. Register a webhook endpoint at
# https://dashboard.stripe.com/test/webhooks pointing to {NEXT_PUBLIC_SITE_URL}/api/stripe/webhook,
# subscribed to: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted — then paste the "Signing secret" (starts with "whsec_") here.
# STRIPE_WEBHOOK_SECRET=
